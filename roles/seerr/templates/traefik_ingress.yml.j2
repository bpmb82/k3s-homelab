apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: {{ srr_service }}
  namespace: {{ srr_kube_namespace }}
spec:
  entryPoints:
    - websecure
  routes:
  - match: Host(`{{ srr_service }}.{{ domain }}`)
    kind: Rule
    services:
      - name: {{ srr_service }}
        port: {{ srr_service_port }}
        scheme: http
  tls:
    certResolver: acme_resolver
