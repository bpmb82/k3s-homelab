apiVersion: monitoring.coreos.com/v1
kind: ServiceMonitor
metadata:
  name: {{ ha_service }}-metrics
  namespace: {{ ha_kube_namespace }}
  labels:
    release: kps
spec:
  selector:
    matchLabels:
      app.kubernetes.io/name: {{ ha_service }}
  namespaceSelector:
    matchNames:
      - {{ ha_kube_namespace }}
  endpoints:
    - port: http
      path: /api/prometheus
      interval: 30s
