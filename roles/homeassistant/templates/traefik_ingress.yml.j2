apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: {{ ha_service }}
  namespace: {{ ha_kube_namespace }}
spec:
  entryPoints:
    - websecure
  routes:
  - match: Host(`{{ ha_service }}.{{ domain }}`)
    kind: Rule
    services:
      - name: {{ ha_service }}
        port: {{ ha_service_port }}
        scheme: http
  tls:
    certResolver: acme_resolver
