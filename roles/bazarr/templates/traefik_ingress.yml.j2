apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: {{ bzr_service }}
  namespace: {{ bzr_kube_namespace }}
spec:
  entryPoints:
    - websecure
  routes:
  - match: Host(`{{ bzr_service }}.{{ domain }}`)
    kind: Rule
    services:
      - name: {{ bzr_service }}
        port: {{ bzr_service_port }}
        scheme: http
  tls:
    certResolver: acme_resolver
