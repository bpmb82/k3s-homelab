apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: {{ snr_service }}
  namespace: {{ snr_kube_namespace }}
spec:
  entryPoints:
    - websecure
  routes:
  - match: Host(`{{ snr_service }}.{{ domain }}`)
    kind: Rule
    services:
      - name: {{ snr_service }}
        port: {{ snr_service_port }}
        scheme: http
  tls:
    certResolver: acme_resolver
