apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: {{ rdr_service }}
  namespace: {{ rdr_kube_namespace }}
spec:
  entryPoints:
    - websecure
  routes:
  - match: Host(`{{ rdr_service }}.{{ domain }}`)
    kind: Rule
    services:
      - name: {{ rdr_service }}
        port: {{ rdr_service_port }}
        scheme: http
  tls:
    certResolver: acme_resolver
