apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: {{ hdscl_sidecar_service }}
  namespace: {{ hdscl_kube_namespace }}
spec:
  entryPoints:
    - websecure
  routes:
  - match: "Host(`{{ hdscl_sidecar_service }}.{{ domain }}`)"
    kind: Rule
    services:
      - name: {{ hdscl_sidecar_service }}
        port: {{ hdscl_sidecar_service_port }}
        scheme: http
  tls:
    certResolver: acme_resolver
