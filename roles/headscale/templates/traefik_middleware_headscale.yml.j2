apiVersion: traefik.io/v1alpha1
kind: Middleware
metadata:
  name: cors
  namespace: {{ hdscl_kube_namespace }}
spec:
  headers:
    accessControlAllowHeaders: 
      - "*"
    accessControlAllowMethods: 
      - "GET"
      - "POST"
      - "PUT"
    accessControlAllowOriginList: 
      - {{ hdscl_service_public_endpoint }}.{{ domain }}
    accessControlMaxAge: 100
    addVaryHeader: true
