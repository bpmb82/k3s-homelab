apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: {{ slskd_service }}
  namespace: {{ slskd_kube_namespace }}
spec:
  entryPoints:
    - websecure
  routes:
  - match: Host(`{{ slskd_service }}.{{ domain }}`)
    kind: Rule
    services:
      - name: {{ slskd_service }}
        port: {{ slskd_service_port }}
        scheme: http
  tls:
    certResolver: acme_resolver
