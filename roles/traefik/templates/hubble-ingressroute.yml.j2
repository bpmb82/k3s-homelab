apiVersion: traefik.io/v1alpha1
kind: IngressRoute
metadata:
  name: hubble-ui
  namespace: kube-system
spec:
  entryPoints:
    - websecure
  routes:
  - match: Host(`hubble.{{ domain }}`)
    kind: Rule
    services:
      - name: hubble-ui
        port: 80
        scheme: http
  tls:
    certResolver: acme_resolver
